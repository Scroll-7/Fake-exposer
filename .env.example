# Groq API key — required for text + vision analysis via LLaMA models
# Get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Google Gemini API keys — used for AI image forensics
# Comma-separated for key rotation; get at https://aistudio.google.com/apikey
GEMINI_API_KEYS=your_key_here

# Server port (optional, default 3001)
PORT=3001
